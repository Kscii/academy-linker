# Academy Linker — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored and must NEVER be committed.

# CurricuLLM-AU key — used for report generation, AI Insight, AI chat
AI_API_KEY=your_curricullm_api_key_here

# Gemini key — used for UI text translation only
GEMINI_API_KEY=your_gemini_api_key_here
