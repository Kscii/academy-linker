FROM python:3.12-slim

# 从官方镜像复制 uv，与项目本地工具链保持一致
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app

# 先复制依赖声明，利用层缓存（依赖未变则不重装）
COPY pyproject.toml ./
COPY src/ src/

# 安装所有依赖及项目本身（--system 写入系统 Python，容器内无需虚拟环境）
RUN uv pip install --system --no-cache .

EXPOSE 8000

CMD ["uvicorn", "ac_link.run:app", "--host", "0.0.0.0", "--port", "8000"]
