POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DEBUG=
REQUEST_TIMING_ENABLED=false
SLOW_REQUEST_THRESHOLD_MS=1000
REQUEST_TIMING_LOG_ALL=false
JWT_SECRET_KEY=
# 用 python -c "import secrets; print(secrets.token_hex(32))" 生成

# 初始管理员账户（用于 python -m ac_link.db.create_admin）
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=

LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-5.4-nano
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# --- CurricuLLM（OpenAI 兼容，针对 K-12 课程对齐优化）---
# 官网：https://curricullm.com/developers
# 将 LLM_BASE_URL 改为下方地址，LLM_API_KEY 填写 CurricuLLM 控制台生成的密钥即可切换
# LLM_BASE_URL=https://api.curricullm.com/v1
# 可用模型（按课程体系选择）：
#   CurricuLLM-AU      澳大利亚课程 v9
#   CurricuLLM-NZ      新西兰课程
#   CurricuLLM-AU-VIC  维多利亚州课程
#   CurricuLLM-AU-WA   西澳大利亚课程
# LLM_MODEL=CurricuLLM-AU

TTS_PROVIDER=gemini
TTS_API_KEY=
TTS_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
TTS_MODEL=gemini-2.5-flash-preview-tts
TTS_VOICE_EN=Kore
TTS_VOICE_ZH=Aoede
TTS_AUDIO_ENCODING=WAV
TTS_AUDIO_SAMPLE_RATE_HERTZ=24000
TTS_STORAGE_DIR=.tts-cache

# API 服务端口（compose 中 api 容器对外暴露的端口）
API_PORT=8000

# 允许跨域请求的前端地址
# 支持 JSON 数组或逗号分隔两种写法，推荐逗号分隔：
# 示例（本地开发）：ALLOWED_ORIGINS=http://localhost:5173
# 示例（多个域名）：ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:5173
