POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DEBUG=
JWT_SECRET_KEY=
# 用 python -c "import secrets; print(secrets.token_hex(32))" 生成

# API 服务端口（compose 中 api 容器对外暴露的端口）
API_PORT=8000

# 允许跨域请求的前端地址，多个地址用逗号分隔
# 示例（本地开发）：ALLOWED_ORIGINS=http://localhost:5173
# 示例（生产）：ALLOWED_ORIGINS=https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:5173

LLM_API_KEY=
LLM_BASE_URL=
# 留空则使用 OpenAI 官方地址；填写后可对接任何兼容 OpenAI API 的提供商
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048