# API 服务端口（compose 中 api 容器对外暴露的端口）
API_PORT=8000

# 允许跨域请求的前端地址，多个地址用逗号分隔
# 示例（本地开发）：ALLOWED_ORIGINS=["http://localhost:5173"]
# 示例（生产）：ALLOWED_ORIGINS=["https://your-frontend-domain.com"]
ALLOWED_ORIGINS=["http://localhost:5173"]